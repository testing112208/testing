# ════════════════════════════════════════════════════════════
# CAB SERVES - PRODUCTION ENVIRONMENT TEMPLATE (.env.production.example)
# ════════════════════════════════════════════════════════════
# Copy these keys to your deployment platform (Render, Vercel, etc.)
# DO NOT COMMIT THE ACTUAL .env FILE TO VERSION CONTROL
# ════════════════════════════════════════════════════════════

# ── DATABASE & CACHE ─────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/cab_serves
REDIS_URL=redis://<user>:<password>@<host>:<port>

# ── SECURITY ────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_high_entropy_random_hex_string

# ── NOTIFICATIONS ───────────────────────────────────────────
# Telegram bot configuration for admin alerts
TELEGRAM_BOT_TOKEN=123456789:ABCDefgh-IJKLmnop-QRSTuv
TELEGRAM_CHAT_ID=-100XXXXXXXXXX

# WhatsApp (Baileys) configuration
WHATSAPP_PHONE=91XXXXXXXXXX
# Set to 'false' if you want WhatsApp active on your deployment
DISABLE_WHATSAPP=false

# ── CROSS-ORIGIN RESOURCE SHARING (CORS) ────────────────────
# The URL of your production frontend (e.g., https://cab-serves.vercel.app)
CLIENT_URL=https://your-frontend-domain.com

# ── FRONTEND CONFIGURATION (NEXT.JS) ────────────────────────
# The URL of your production backend (e.g., https://cab-serves-api.onrender.com)
NEXT_PUBLIC_API_URL=https://your-backend-api.onrender.com

# ── OTHER ──────────────────────────────────────────────────
NODE_ENV=production
PORT=10000
RENDER_EXTERNAL_URL=https://your-backend-api.onrender.com
NEXT_PUBLIC_WHATSAPP_PHONE=91XXXXXXXXXX
