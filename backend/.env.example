# ══════════════════════════════════════════════════════════════════
# BACKEND ENVIRONMENT VARIABLES - .env.example
# ══════════════════════════════════════════════════════════════════
# Copy this file to .env for local dev.
# On Render: set ALL these as Environment Variables in the dashboard.
# NEVER commit .env with real values to git.
# ══════════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development           # Change to: production on Render

# ── Database ────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# ── Auth ────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_char_random_hex_string_here

# ── Frontend Origin ─────────────────────────────────────────────
# Local:      http://localhost:3000
# Cloudflare: https://your-project.pages.dev
CLIENT_URL=http://localhost:3000

# ── Admin Bootstrap ─────────────────────────────────────────────
# Email to match when prompting to run reset-admin.js
# Run: node reset-admin.js to create the first admin account
ADMIN_BOOTSTRAP_EMAIL=your-admin@email.com

# ── Notifications ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── WhatsApp (Optional) ─────────────────────────────────────────
# Set DISABLE_WHATSAPP=true on Render free tier (low RAM)
# Set DISABLE_WHATSAPP=false on paid plan or local dev
DISABLE_WHATSAPP=true
WHATSAPP_PHONE=91XXXXXXXXXX     # Format: 91 + 10-digit number

# ── WhatsApp on Linux (Render paid) ─────────────────────────────
# Set the path to chromium on your server
# CHROME_PATH=/usr/bin/chromium-browser

# ── Redis Cache ─────────────────────────────────────────────────
REDIS_URL=redis://:<password>@<host>:<port>
